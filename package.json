{
  "name": "educhain-stellar",
  "version": "1.0.0",
  "description": "EduLedger - Decentralized Education Platform on Stellar",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "deploy": "npm run build && node dist/deploy.js",
    "lint": "eslint 'src/**/*.ts' 'stellar/**/*.ts' 'storage/**/*.ts' --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "blockchain",
    "education",
    "stellar",
    "credentials",
    "web3",
    "nft"
  ],
  "author": "EduLedger Team",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^12.1.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ipfs-http-client": "^60.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.6",
    "@types/node": "^20.8.0",
    "@types/supertest": "^2.0.15",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "undici": ">=6.26.1",
    "parse-duration": ">=2.1.3"
  }
}
